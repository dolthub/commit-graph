{
  "name": "commit-graph",
  "version": "2.3.12",
  "homepage": "https://liuliu-dev.github.io/CommitGraph/",
  "author": "Liu Liu <liuliu.developer@gmail.com>",
  "description": "A React component to visualize a commit graph.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "yarn@4.13.0",
  "contributors": [
    {
      "name": "Xiang Zhu",
      "email": "zxwind@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/liuliu-dev/CommitGraph"
  },
  "license": "MIT",
  "keywords": [
    "commit",
    "graph",
    "react"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "rollup -c --bundleConfigAsCjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "prettier": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css}\"",
    "prettier-fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css}\"",
    "compile": "tsc -b",
    "ci": "npm-run-all prettier lint test build build-storybook",
    "deploy-storybook": "gh-pages -d storybook-static"
  },
  "dependencies": {
    "classnames": "^2.3.2",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-icons": "^5.3.0",
    "react-infinite-scroller": "^1.2.6",
    "react-tooltip": "^5.26.3",
    "reactjs-popup": "^2.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react": "^10",
    "@storybook/react-webpack5": "^10",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-infinite-scroller": "^1.2.5",
    "eslint": "^10",
    "eslint-config-prettier": "^10.0.1",
    "gh-pages": "^6.1.1",
    "jest": "^30.2.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.2.5",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10",
    "ts-jest": "^29.1.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "jest": {
    "transform": {
      ".(ts|tsx)": "ts-jest"
    },
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ]
  }
}
